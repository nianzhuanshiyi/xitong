# 本地开发：仓库默认 prisma/schema.prisma 为 SQLite
DATABASE_URL="file:./dev.db"
#
# Railway / 线上：环境变量用 PostgreSQL 的 DATABASE_URL（与本地不同没关系）。
# 线上建表与生成 Client 必须用 Postgres 专用 schema 文件，不要用默认 npm run build 里的 prisma generate（会按 SQLite 生成）。
# 在 Railway → Settings → Build → Custom Build Command 填：
#   npx prisma db push --accept-data-loss --schema=prisma/schema.postgresql.prisma && npx prisma generate --schema=prisma/schema.postgresql.prisma && next build
#
# Start Command（空库时写入默认管理员 admin@example.com / admin123，与 prisma db seed 相同逻辑）任选其一：
#   npm run start:prod
# 或完整命令：
#   npx prisma db push --accept-data-loss --schema=prisma/schema.postgresql.prisma && npx prisma db seed --schema=prisma/schema.postgresql.prisma && npm run start
# 应用也会在启动时（instrumentation）检测空库并补种；若只想用 CLI 种子可设 SKIP_BOOTSTRAP_SEED=1
#
# 若你仍用 Supabase pooler，可把线上 DATABASE_URL 设为 6543 + ?pgbouncer=true（密码特殊字符须 URL 编码：! %21、@ %40、# %23）。
# DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="请替换为至少 32 位随机字符串"

# Anthropic Claude（可选：也可仅在后台「设置」中写入数据库备用密钥）
CLAUDE_API_KEY=
# 可选：覆盖默认模型（选品分析、供应商 AI 等均走 claude-client）
# CLAUDE_ANALYSIS_MODEL=claude-opus-4-6
# 可选：设置页「测试 Claude」使用的模型 ID
# CLAUDE_TEST_MODEL=claude-opus-4-6

# 邮件中心（企业网易邮箱示例；MAIL_UI_MOCK=1 时使用演示数据，不接真实邮箱）
# MAIL_UI_MOCK=0
# MAIL_SYNC_SINCE_DAYS=7
# IMAP_HOST=imap.qiye.163.com
# IMAP_PORT=993
# SMTP_HOST=smtp.qiye.163.com
# SMTP_PORT=465
# EMAIL_USER=your@company.com
# 若授权码含字符 $，请写成 $$（Next.js dotenv-expand）
# EMAIL_AUTH_CODE=your_authorization_code

# Google AI（Imagen 图片生成，AI 图片模块）
GOOGLE_AI_API_KEY=
# 可选：覆盖 Imagen 模型 ID（默认 imagen-4.0-generate-001）
# GOOGLE_IMAGEN_MODEL=imagen-4.0-generate-001

# 卖家精灵 MCP
SELLERSPRITE_MCP_URL=https://mcp.sellersprite.com/mcp
SELLERSPRITE_SECRET_KEY=

# Perplexity（AI 助手实时搜索）
PERPLEXITY_API_KEY=
