generator client {
  provider = "prisma-client-js"
}

/// 与 `schema.prisma` 模型一致；仅线上（Railway）用 `--schema` 指向本文件。本地默认用 SQLite。
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

model User {
  id                      String                  @id @default(cuid())
  name                    String?
  email                   String?                 @unique
  emailVerified           DateTime?
  image                   String?
  password                String?
  role                    UserRole                @default(EMPLOYEE)
  aiAuthorized            Boolean                 @default(true)
  assignedModel           String                  @default("claude-sonnet-4-20250514")
  monthlyTokenLimit       Int                     @default(500000)
  allowedModules          String?                 @db.Text
  teamId                  String?
  team                    Team?                   @relation(fields: [teamId], references: [id], onDelete: SetNull)
  accounts                Account[]
  sessions                Session[]
  operationLogs           OperationLog[]
  productAnalysisReports  ProductAnalysisReport[]
  analysisCaches          AnalysisCache[]
  smartSelectionPlans     SmartSelectionPlan[]
  listingDrafts           ListingDraft[]
  imageProjects           ImageProject[]
  assignedActionItems     ActionItem[]            @relation("ActionItemAssignee")
  emailAccounts           EmailAccount[]
  productAnalyses         ProductAnalysis[]
  productIdeas            ProductIdea[]
  ideaComments            IdeaComment[]
  topPickReports          TopPickReport[]
  threeCProductIdeas      ThreeCProductIdea[]
  threeCIdeaComments      IdeaComment3C[]         @relation("ThreeCIdeaComments")
  threeCTopPickReports    ThreeCTopPickReport[]
  europeProductIdeas      EuropeProductIdea[]
  europeIdeaComments      IdeaCommentEurope[]     @relation("EuropeIdeaComments")
  europeTopPickReports    EuropeTopPickReport[]
  auCompetitorStores      AuCompetitorStore[]
  auCategoryOpportunities AuCategoryOpportunity[]
  auStorePlans            AuStorePlan[]
  auMilestones            AuMilestone[]
  auDevAnalyses           AuDevAnalysis[]
  activityLogs            ActivityLog[]
  feedbacks               Feedback[]
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
}

/// AI 图片模块：亚马逊 Listing 用图类型
enum AiImageType {
  MAIN_WHITE
  LIFESTYLE
  INFOGRAPHIC
  SIZE_COMPARE
  MODEL_USE
  BEFORE_AFTER
  PACKAGING
  APLUS_STORY
}

/// 产品图片项目（每个产品一个）
model ImageProject {
  id                 String           @id @default(cuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String
  /// 关联亚马逊 ASIN（可选）
  asin               String?
  category           String           @default("")
  description        String           @default("")
  /// 参考图相对路径 JSON 数组，最多 5 张：["uploads/ai-images/{id}/ref/xxx.jpg"]
  referencePathsJson String           @default("[]")
  /// 新建项目时 AI 推荐的 7 张图策略（JSON）
  bundlePlanJson     String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  generatedImages    GeneratedImage[]
}

/// Imagen / Gemini 等生成的图片记录
model GeneratedImage {
  id            String       @id @default(cuid())
  projectId     String
  project       ImageProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  imageType     AiImageType
  /// 用户侧简短描述（Gemini 流程：产品描述原文）
  prompt        String       @default("")
  /// 实际送模型的完整提示词
  fullPrompt    String       @default("")
  promptEn      String
  promptZh      String       @default("")
  paramsJson    String       @default("{}")
  /// 外链或占位（可选）
  imageUrl      String       @default("")
  /// Base64 图片数据（Gemini 等内联存储）
  imageData     String?      @db.Text
  /// 风格：main_image / lifestyle / white_bg / infographic / custom
  style         String       @default("main_image")
  status        String       @default("completed")
  width         Int          @default(1024)
  height        Int          @default(1024)
  /// 相对网站根路径；纯 Base64 时可为空字符串
  filePath      String       @default("")
  isFavorite    Boolean      @default(false)
  /// 亚马逊 7 张套装中的位置 0–6，未编入套装则为 null
  sortPosition  Int?
  parentImageId String?
  createdAt     DateTime     @default(now())
}

enum ListingDraftStatus {
  DRAFT
  COMPLETED
  USED
}

/// Listing 撰写草稿
model ListingDraft {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketplace String
  category    String
  productName String
  brandName   String
  inputJson   String
  resultJson  String?
  status      ListingDraftStatus @default(DRAFT)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([userId, updatedAt])
}

enum SmartSelectionResultStatus {
  RECOMMENDED
  CANDIDATE
  EXCLUDED
  PASSED_HARD
  REJECTED_AI
}

/// 智能选品方案（每套独立筛选条件与历史）
model SmartSelectionPlan {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  marketplace String
  category    String?
  filtersJson String
  active      Boolean  @default(true)
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  batches  SmartSelectionScanBatch[]
  results  SmartSelectionResult[]
  excludes SmartSelectionExcludeList[]
}

/// 单次扫描批次（同一批的推荐结果共享 batchId）
model SmartSelectionScanBatch {
  id        String             @id @default(cuid())
  planId    String
  plan      SmartSelectionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  statsJson String?
  createdAt DateTime           @default(now())

  results SmartSelectionResult[]

  @@index([planId, createdAt])
}

/// 扫描结果 / 候选 / 曾评估记录
model SmartSelectionResult {
  id           String                     @id @default(cuid())
  planId       String
  plan         SmartSelectionPlan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  batchId      String?
  batch        SmartSelectionScanBatch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)
  asin         String
  marketplace  String
  productJson  String
  imageUrl     String?
  title        String?
  price        Float?
  bsr          Int?
  rating       Float?
  reviewCount  Int?
  monthlySales Int?
  aiScore      Int?
  aiSummary    String?
  aiJson       String?
  status       SmartSelectionResultStatus @default(RECOMMENDED)
  createdAt    DateTime                   @default(now())

  @@index([planId, asin])
  @@index([planId, status, createdAt])
  @@index([batchId])
}

/// 排除列表（不感兴趣）
model SmartSelectionExcludeList {
  id        String             @id @default(cuid())
  planId    String
  plan      SmartSelectionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  asin      String
  reason    String?
  createdAt DateTime           @default(now())

  @@unique([planId, asin])
}

/// 选品分析结果缓存（按站点+ASIN 组合+利润参数键；默认约 90 天过期）
model AnalysisCache {
  id             String   @id @default(cuid())
  cacheKey       String   @unique
  asin           String
  marketplace    String
  analysisData   String
  reportMarkdown String
  score          Int
  expiresAt      DateTime
  analyzedById   String
  analyzedBy     User     @relation(fields: [analyzedById], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([asin])
  @@index([marketplace])
  @@index([expiresAt])
}

model ProductAnalysisReport {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketplace String
  asinsJson   String
  title       String?
  score       Int?
  scoreBand   String?
  status      String
  resultJson  String?
  createdAt   DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  tokenUsed   Int      @default(0)
  tokenLimit  Int      @default(100000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

enum SupplierStatus {
  COOPERATING
  EVALUATING
  CANDIDATE
  REJECTED
}

enum SupplierFileCategory {
  CATALOG
  PRICE_LIST
  TEST_REPORT
  CERTIFICATION
  CONTRACT
  PACKAGING
  PRODUCT_IMAGE
  OTHER
}

model Supplier {
  id                   String         @id @default(cuid())
  name                 String
  nameEn               String?
  country              String
  countryCode          String?
  website              String?
  address              String?
  mainCategories       String?
  contact              String?
  paymentTerms         String?
  moq                  String?
  sampleLeadDays       Int?
  productionLeadDays   Int?
  cooperationStartDate DateTime?
  remarks              String?
  status               SupplierStatus @default(EVALUATING)
  overallScore         Float?
  logoUrl              String?
  profileSummary       String?
  aiEvaluationJson     String?
  websiteScrapedAt     DateTime?
  lastActivityAt       DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  contacts        SupplierContact[]
  files           SupplierFile[]
  ratings         SupplierRatingEntry[]
  orders          SupplierOrder[]
  samples         SupplierSample[]
  qualityIssues   SupplierQualityIssue[]
  supplierNotes   SupplierNote[]
  products        Product[]
  emails          Email[]
  supplierDomains SupplierDomain[]
  actionItems     ActionItem[]
  productAnalyses ProductAnalysis[]

  @@index([status])
}

/// 邮件方向
enum EmailDirection {
  RECEIVED
  SENT
}

/// 紧急程度（邮件与待办共用）
enum MailPriority {
  URGENT
  NORMAL
  LOW
}

/// 邮箱账号配置（每个用户可配置多个邮箱）
model EmailAccount {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  email        String
  displayName  String?
  imapHost     String
  imapPort     Int       @default(993)
  /// 加密存储的 IMAP 密码/授权码
  imapPassword String
  smtpHost     String?
  smtpPort     Int?      @default(465)
  /// 加密存储的 SMTP 密码/授权码（为空时复用 imapPassword）
  smtpPassword String?
  /// 纯文本邮件签名
  signature    String?
  isActive     Boolean   @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  emails    Email[]
  syncState ImapSyncState?

  @@unique([userId, email])
  @@index([userId, isActive])
}

/// 供应商邮件
model Email {
  id             String         @id @default(cuid())
  accountId      String?
  account        EmailAccount?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  supplierId     String?
  supplier       Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  messageId      String         @unique
  inReplyTo      String?
  referencesIds  String?
  direction      EmailDirection
  fromAddress    String
  toAddress      String
  subject        String
  bodyText       String         @default("")
  bodyHtml       String?
  /// AI 全文中文翻译（展示用）
  bodyZh         String?
  receivedAt     DateTime
  summaryCn      String?
  priority       MailPriority   @default(NORMAL)
  tagsJson       String         @default("[]")
  /// 未归类邮件的 AI 分组：logistics / invoice / inquiry / fair / other
  aiBucket       String?
  isRead         Boolean        @default(false)
  isClassified   Boolean        @default(false)
  /// 软删除：列表与详情均不展示
  isDeleted      Boolean        @default(false)
  isStarred      Boolean        @default(false)
  /// 归档后从默认收件列表隐藏
  isArchived     Boolean        @default(false)
  imapUid        Int?
  hasAttachments Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  attachments     EmailAttachment[]
  actionItems     ActionItem[]
  productAnalyses ProductAnalysis[]

  @@index([accountId, receivedAt])
  @@index([supplierId, receivedAt])
  @@index([supplierId, isRead])
  @@index([receivedAt])
  @@index([isDeleted, receivedAt])
}

model EmailAttachment {
  id          String   @id @default(cuid())
  emailId     String
  email       Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  filename    String
  contentType String
  sizeBytes   Int
  storagePath String
  createdAt   DateTime @default(now())
}

model ActionItem {
  id          String       @id @default(cuid())
  emailId     String?
  email       Email?       @relation(fields: [emailId], references: [id], onDelete: SetNull)
  supplierId  String?
  supplier    Supplier?    @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?        @relation("ActionItemAssignee", fields: [userId], references: [id], onDelete: SetNull)
  content     String
  isCompleted Boolean      @default(false)
  dueDate     DateTime?
  priority    MailPriority @default(NORMAL)
  completedAt DateTime?
  createdAt   DateTime     @default(now())

  @@index([supplierId, isCompleted])
  @@index([isCompleted, priority])
  @@index([isCompleted])
}

model SupplierDomain {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  domain     String   @unique
  createdAt  DateTime @default(now())
}

model ImapSyncState {
  id           String        @id @default(cuid())
  /// 兼容旧数据：字符串邮箱账号（新数据请用 accountId）
  emailAccount String?       @unique
  accountId    String?       @unique
  account      EmailAccount? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  lastUid      Int           @default(0)
  lastSyncAt   DateTime?
  status       String        @default("active")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model SupplierContact {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name       String
  title      String?
  email      String?
  phone      String?
  wechat     String?
  whatsapp   String?
  lineId     String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SupplierFile {
  id           String               @id @default(cuid())
  supplierId   String
  supplier     Supplier             @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  storedName   String
  originalName String
  mimeType     String
  size         Int
  category     SupplierFileCategory @default(OTHER)
  relativePath String
  fileData     Bytes?
  uploadedAt   DateTime             @default(now())

  analysis SupplierFileAnalysis?
}

model SupplierFileAnalysis {
  id              String       @id @default(cuid())
  fileId          String       @unique
  file            SupplierFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  summary         String?
  structuredJson  String?
  complianceNotes String?
  certExpiryDate  DateTime?
  rawResponse     String?
  createdAt       DateTime     @default(now())
}

model SupplierRatingEntry {
  id            String   @id @default(cuid())
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  quality       Int
  priceCompete  Int
  delivery      Int
  communication Int
  cooperation   Int
  rdCapability  Int
  comment       String?
  createdAt     DateTime @default(now())
}

model SupplierOrder {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  orderDate   DateTime
  productDesc String
  quantity    Int?
  amount      Float?
  currency    String?  @default("USD")
  status      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SupplierSample {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  sampleDate  DateTime
  productDesc String
  status      String?
  notes       String?
  createdAt   DateTime @default(now())
}

model SupplierQualityIssue {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  issueDate   DateTime @default(now())
  description String
  severity    String?
  createdAt   DateTime @default(now())
}

model SupplierNote {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  title      String?
  content    String
  createdAt  DateTime @default(now())
}

model Product {
  id           String    @id @default(cuid())
  asin         String    @unique
  category     String
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  analysisData String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model OperationLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  resource  String?
  details   String?
  createdAt DateTime @default(now())
}

model InviteCode {
  id        String    @id @default(cuid())
  code      String    @unique
  maxUses   Int       @default(1)
  usedCount Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

/// 全局系统设置（如 AI 默认模型等）
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

/// 后台保存的 API 密钥（.env 存在同名变量时优先使用环境变量）
model IntegrationSecret {
  id                 String   @id @default("default")
  claudeApiKey       String?
  sellerspriteSecret String?
  aiAssistantModel   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── 产品开发模块 ───────────────────────────────────────────

/// 产品开发项目
model ProductDev {
  id               String    @id @default(cuid())
  name             String
  asin             String?
  category         String?
  targetMarket     String    @default("US")
  /// idea / research / sampling / testing / listing / launched / abandoned
  status           String    @default("idea")
  /// low / medium / high / urgent
  priority         String    @default("medium")
  description      String?
  targetPrice      Float?
  estimatedCost    Float?
  estimatedProfit  Float?
  moq              Int?
  /// JSON 数组：竞品 ASIN 列表
  competitorAsins  String?
  marketSize       String?
  competitionLevel String?
  supplierName     String?
  supplierContact  String?
  /// not_ordered / ordered / received / approved / rejected
  sampleStatus     String?
  sampleCost       Float?
  /// 差异化卖点
  diffPoints       String?
  /// 用户痛点
  painPoints       String?
  ideaDate         DateTime  @default(now())
  targetLaunchDate DateTime?
  actualLaunchDate DateTime?
  notes            String?
  imageUrl         String?
  createdBy        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tasks ProductDevTask[]
  logs  ProductDevLog[]

  @@index([status])
  @@index([priority])
  @@index([createdBy])
}

/// 产品开发任务
model ProductDevTask {
  id          String     @id @default(cuid())
  productId   String
  product     ProductDev @relation(fields: [productId], references: [id], onDelete: Cascade)
  title       String
  description String?
  /// todo / in_progress / done
  status      String     @default("todo")
  assignee    String?
  dueDate     DateTime?
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([productId, sortOrder])
}

/// 产品开发操作日志
model ProductDevLog {
  id        String     @id @default(cuid())
  productId String
  product   ProductDev @relation(fields: [productId], references: [id], onDelete: Cascade)
  action    String
  content   String
  createdBy String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([productId, createdAt])
}

/// AI 产品分析
model ProductAnalysis {
  id             String    @id @default(cuid())
  emailId        String?
  email          Email?    @relation(fields: [emailId], references: [id], onDelete: SetNull)
  supplierId     String?
  supplier       Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdById    String
  createdBy      User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  productName    String    @default("")
  query          String
  analysisResult String?
  marketData     String?
  score          Int?
  /// strong_yes / yes / maybe / no / strong_no
  recommendation String?
  /// pending / analyzing / completed / failed
  status         String    @default("pending")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  chats AnalysisChat[]

  @@index([createdById, createdAt])
  @@index([supplierId, createdAt])
}

/// AI 分析对话历史
model AnalysisChat {
  id         String          @id @default(cuid())
  analysisId String
  analysis   ProductAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  /// user / assistant
  role       String
  content    String
  createdAt  DateTime        @default(now())

  @@index([analysisId, createdAt])
}

// ─── 美妆新品创意模块 ───────────────────────────────────────

/// 美妆趋势
model BeautyTrend {
  id          String   @id @default(cuid())
  /// google_trends / social_media / news / industry_report
  source      String
  /// US / KR / CN
  market      String
  title       String
  content     String
  /// JSON 数组，如 ["玻尿酸","烟酰胺"]
  ingredients String   @default("[]")
  /// skincare / makeup / haircare / bodycare / fragrance
  category    String
  trendScore  Int      @default(50)
  sourceUrl   String?
  scannedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ideas ProductIdea[]

  @@index([market, createdAt])
  @@index([category, createdAt])
}

/// 新品创意
model ProductIdea {
  id             String       @id @default(cuid())
  trendId        String?
  trend          BeautyTrend? @relation(fields: [trendId], references: [id], onDelete: SetNull)
  name           String
  /// skincare / makeup / haircare / bodycare / fragrance
  category       String
  description    String
  targetMarket   String       @default("US")
  /// JSON 数组
  keyIngredients String       @default("[]")
  /// JSON 数组
  sellingPoints  String       @default("[]")
  estimatedPrice String?
  estimatedCost  String?

  /// 卖家精灵市场数据 JSON
  marketData       String?
  searchVolume     Int?
