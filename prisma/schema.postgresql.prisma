generator client {
  provider = "prisma-client-js"
}

/// 与 `schema.prisma` 模型一致；仅线上（Railway）用 `--schema` 指向本文件。本地默认用 SQLite。
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

model User {
  id                     String                  @id @default(cuid())
  name                   String?
  email                  String?                 @unique
  emailVerified          DateTime?
  image                  String?
  password               String?
  role                   UserRole                @default(EMPLOYEE)
  aiAuthorized           Boolean                 @default(false)
  teamId                 String?
  team                   Team?                   @relation(fields: [teamId], references: [id], onDelete: SetNull)
  accounts               Account[]
  sessions               Session[]
  operationLogs          OperationLog[]
  productAnalysisReports ProductAnalysisReport[]
  analysisCaches         AnalysisCache[]
  smartSelectionPlans    SmartSelectionPlan[]
  listingDrafts          ListingDraft[]
  imageProjects          ImageProject[]
  assignedActionItems    ActionItem[]            @relation("ActionItemAssignee")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

/// AI 图片模块：亚马逊 Listing 用图类型
enum AiImageType {
  MAIN_WHITE
  LIFESTYLE
  INFOGRAPHIC
  SIZE_COMPARE
  MODEL_USE
  BEFORE_AFTER
  PACKAGING
  APLUS_STORY
}

/// 产品图片项目（每个产品一个）
model ImageProject {
  id               String           @id @default(cuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  /// 关联亚马逊 ASIN（可选）
  asin             String?
  category         String           @default("")
  description      String           @default("")
  /// 参考图相对路径 JSON 数组，最多 5 张：["uploads/ai-images/{id}/ref/xxx.jpg"]
  referencePathsJson String         @default("[]")
  /// 新建项目时 AI 推荐的 7 张图策略（JSON）
  bundlePlanJson   String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  generatedImages  GeneratedImage[]
}

/// Imagen / Gemini 等生成的图片记录
model GeneratedImage {
  id             String      @id @default(cuid())
  projectId      String
  project        ImageProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  imageType      AiImageType
  /// 用户侧简短描述（Gemini 流程：产品描述原文）
  prompt         String      @default("")
  /// 实际送模型的完整提示词
  fullPrompt     String      @default("")
  promptEn       String
  promptZh       String      @default("")
  paramsJson     String      @default("{}")
  /// 外链或占位（可选）
  imageUrl       String      @default("")
  /// Base64 图片数据（Gemini 等内联存储）
  imageData      String?     @db.Text
  /// 风格：main_image / lifestyle / white_bg / infographic / custom
  style          String      @default("main_image")
  status         String      @default("completed")
  width          Int         @default(1024)
  height         Int         @default(1024)
  /// 相对网站根路径；纯 Base64 时可为空字符串
  filePath       String      @default("")
  isFavorite     Boolean     @default(false)
  /// 亚马逊 7 张套装中的位置 0–6，未编入套装则为 null
  sortPosition   Int?
  parentImageId  String?
  createdAt      DateTime    @default(now())
}

enum ListingDraftStatus {
  DRAFT
  COMPLETED
  USED
}

/// Listing 撰写草稿
model ListingDraft {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketplace String
  category    String
  productName String
  brandName   String
  inputJson   String
  resultJson  String?
  status      ListingDraftStatus  @default(DRAFT)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([userId, updatedAt])
}

enum SmartSelectionResultStatus {
  RECOMMENDED
  CANDIDATE
  EXCLUDED
  PASSED_HARD
  REJECTED_AI
}

/// 智能选品方案（每套独立筛选条件与历史）
model SmartSelectionPlan {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  marketplace String
  category    String?
  filtersJson String
  active      Boolean  @default(true)
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  batches  SmartSelectionScanBatch[]
  results  SmartSelectionResult[]
  excludes SmartSelectionExcludeList[]
}

/// 单次扫描批次（同一批的推荐结果共享 batchId）
model SmartSelectionScanBatch {
  id        String   @id @default(cuid())
  planId    String
  plan      SmartSelectionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  statsJson String?
  createdAt DateTime @default(now())

  results SmartSelectionResult[]

  @@index([planId, createdAt])
}

/// 扫描结果 / 候选 / 曾评估记录
model SmartSelectionResult {
  id          String                       @id @default(cuid())
  planId      String
  plan        SmartSelectionPlan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  batchId     String?
  batch       SmartSelectionScanBatch?     @relation(fields: [batchId], references: [id], onDelete: SetNull)
  asin        String
  marketplace String
  productJson String
  imageUrl    String?
  title       String?
  price       Float?
  bsr         Int?
  rating      Float?
  reviewCount Int?
  monthlySales Int?
  aiScore     Int?
  aiSummary   String?
  aiJson      String?
  status      SmartSelectionResultStatus   @default(RECOMMENDED)
  createdAt   DateTime                     @default(now())

  @@index([planId, asin])
  @@index([planId, status, createdAt])
  @@index([batchId])
}

/// 排除列表（不感兴趣）
model SmartSelectionExcludeList {
  id        String             @id @default(cuid())
  planId    String
  plan      SmartSelectionPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  asin      String
  reason    String?
  createdAt DateTime           @default(now())

  @@unique([planId, asin])
}

/// 选品分析结果缓存（按站点+ASIN 组合+利润参数键；默认约 90 天过期）
model AnalysisCache {
  id             String   @id @default(cuid())
  cacheKey       String   @unique
  asin           String
  marketplace    String
  analysisData   String
  reportMarkdown String
  score          Int
  expiresAt      DateTime
  analyzedById   String
  analyzedBy     User     @relation(fields: [analyzedById], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([asin])
  @@index([marketplace])
  @@index([expiresAt])
}

model ProductAnalysisReport {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketplace String
  asinsJson   String
  title       String?
  score       Int?
  scoreBand   String?
  status      String
  resultJson  String?
  createdAt   DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  tokenUsed   Int      @default(0)
  tokenLimit  Int      @default(100000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

enum SupplierStatus {
  COOPERATING
  EVALUATING
  CANDIDATE
  REJECTED
}

enum SupplierFileCategory {
  CATALOG
  PRICE_LIST
  TEST_REPORT
  CERTIFICATION
  CONTRACT
  PACKAGING
  PRODUCT_IMAGE
  OTHER
}

model Supplier {
  id                   String         @id @default(cuid())
  name                 String
  nameEn               String?
  country              String
  countryCode          String?
  website              String?
  address              String?
  mainCategories       String?
  contact              String?
  paymentTerms         String?
  moq                  String?
  sampleLeadDays       Int?
  productionLeadDays   Int?
  cooperationStartDate DateTime?
  remarks              String?
  status               SupplierStatus @default(EVALUATING)
  overallScore         Float?
  logoUrl              String?
  profileSummary       String?
  aiEvaluationJson     String?
  websiteScrapedAt     DateTime?
  lastActivityAt       DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  contacts      SupplierContact[]
  files         SupplierFile[]
  ratings       SupplierRatingEntry[]
  orders        SupplierOrder[]
  samples       SupplierSample[]
  qualityIssues SupplierQualityIssue[]
  supplierNotes SupplierNote[]
  products      Product[]
  emails        Email[]
  supplierDomains SupplierDomain[]
  actionItems   ActionItem[]
}

/// 邮件方向
enum EmailDirection {
  RECEIVED
  SENT
}

/// 紧急程度（邮件与待办共用）
enum MailPriority {
  URGENT
  NORMAL
  LOW
}

/// 供应商邮件
model Email {
  id              String         @id @default(cuid())
  supplierId      String?
  supplier        Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  messageId       String         @unique
  inReplyTo       String?
  referencesIds   String?
  direction       EmailDirection
  fromAddress     String
  toAddress       String
  subject         String
  bodyText        String         @default("")
  bodyHtml        String?
  /// AI 全文中文翻译（展示用）
  bodyZh          String?
  receivedAt      DateTime
  summaryCn       String?
  priority        MailPriority   @default(NORMAL)
  tagsJson        String         @default("[]")
  /// 未归类邮件的 AI 分组：logistics / invoice / inquiry / fair / other
  aiBucket        String?
  isRead          Boolean        @default(false)
  isClassified    Boolean        @default(false)
  /// 软删除：列表与详情均不展示
  isDeleted       Boolean        @default(false)
  isStarred       Boolean        @default(false)
  /// 归档后从默认收件列表隐藏
  isArchived      Boolean        @default(false)
  imapUid         Int?
  hasAttachments  Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  attachments EmailAttachment[]
  actionItems ActionItem[]

  @@index([supplierId, receivedAt])
  @@index([supplierId, isRead])
  @@index([receivedAt])
}

model EmailAttachment {
  id          String   @id @default(cuid())
  emailId     String
  email       Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  filename    String
  contentType String
  sizeBytes   Int
  storagePath String
  createdAt   DateTime @default(now())
}

model ActionItem {
  id          String       @id @default(cuid())
  emailId     String?
  email       Email?       @relation(fields: [emailId], references: [id], onDelete: SetNull)
  supplierId  String?
  supplier    Supplier?    @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?        @relation("ActionItemAssignee", fields: [userId], references: [id], onDelete: SetNull)
  content     String
  isCompleted Boolean      @default(false)
  dueDate     DateTime?
  priority    MailPriority @default(NORMAL)
  completedAt DateTime?
  createdAt   DateTime     @default(now())

  @@index([supplierId, isCompleted])
  @@index([isCompleted, priority])
}

model SupplierDomain {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  domain     String   @unique
  createdAt  DateTime @default(now())
}

model ImapSyncState {
  id           String    @id @default(cuid())
  emailAccount String    @unique
  lastUid      Int       @default(0)
  lastSyncAt   DateTime?
  status       String    @default("active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model SupplierContact {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name        String
  title       String?
  email       String?
  phone       String?
  wechat      String?
  whatsapp    String?
  lineId      String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SupplierFile {
  id           String               @id @default(cuid())
  supplierId   String
  supplier     Supplier             @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  storedName   String
  originalName String
  mimeType     String
  size         Int
  category     SupplierFileCategory @default(OTHER)
  relativePath String
  uploadedAt   DateTime             @default(now())

  analysis SupplierFileAnalysis?
}

model SupplierFileAnalysis {
  id              String       @id @default(cuid())
  fileId          String       @unique
  file            SupplierFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  summary         String?
  structuredJson  String?
  complianceNotes String?
  certExpiryDate  DateTime?
  rawResponse     String?
  createdAt       DateTime     @default(now())
}

model SupplierRatingEntry {
  id            String   @id @default(cuid())
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  quality       Int
  priceCompete  Int
  delivery      Int
  communication Int
  cooperation   Int
  rdCapability  Int
  comment       String?
  createdAt     DateTime @default(now())
}

model SupplierOrder {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  orderDate   DateTime
  productDesc String
  quantity    Int?
  amount      Float?
  currency    String?  @default("USD")
  status      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SupplierSample {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  sampleDate  DateTime
  productDesc String
  status      String?
  notes       String?
  createdAt   DateTime @default(now())
}

model SupplierQualityIssue {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  issueDate   DateTime @default(now())
  description String
  severity    String?
  createdAt   DateTime @default(now())
}

model SupplierNote {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  title       String?
  content     String
  createdAt   DateTime @default(now())
}

model Product {
  id           String    @id @default(cuid())
  asin         String    @unique
  category     String
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  analysisData String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model OperationLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  resource  String?
  details   String?
  createdAt DateTime @default(now())
}

model InviteCode {
  id        String    @id @default(cuid())
  code      String    @unique
  maxUses   Int       @default(1)
  usedCount Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

/// 后台保存的 API 密钥（.env 存在同名变量时优先使用环境变量）
model IntegrationSecret {
  id                 String   @id @default("default")
  claudeApiKey       String?
  sellerspriteSecret String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
